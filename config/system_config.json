{\n    \"system\": {\n        \"name\": \"Portable Solar Power Generator\",\n        \"version\": \"1.0.0\",\n        \"college\": \"MS Engineering College\",\n        \"university\": \"Visvesvaraya Technological University\",\n        \"project_type\": \"Final Year Project\"\n    },\n    \"team\": {\n        \"leader\": \"Ritik Pandey\",\n        \"developer\": \"Rohit Ranjan\",\n        \"documentation\": \"Nikki Kumari Yadav\",\n        \"research\": \"Om Singh\"\n    },\n    \"hardware\": {\n        \"solar_panel\": {\n            \"power_rating_w\": 20,\n            \"voltage_nominal\": 12.0,\n            \"voltage_max\": 20.0,\n            \"type\": \"polycrystalline\",\n            \"efficiency\": 0.85\n        },\n        \"battery\": {\n            \"capacity_ah\": 8,\n            \"voltage_nominal\": 12.0,\n            \"voltage_min\": 10.5,\n            \"voltage_max\": 14.4,\n            \"type\": \"VRLA\",\n            \"low_battery_threshold\": 15.0,\n            \"critical_battery_threshold\": 5.0\n        },\n        \"charge_controller\": {\n            \"type\": \"PWM\",\n            \"current_rating\": 20,\n            \"voltage_rating\": 12,\n            \"efficiency\": 0.93\n        }\n    },\n    \"devices\": {\n        \"light\": {\n            \"power_w\": 5,\n            \"voltage\": 12,\n            \"consumption_rate\": 0.5\n        },\n        \"fan\": {\n            \"power_w\": 10,\n            \"voltage\": 12,\n            \"consumption_rate\": 1.0\n        },\n        \"mobile_charger\": {\n            \"power_w\": 10,\n            \"voltage\": 5,\n            \"consumption_rate\": 0.8\n        }\n    },\n    \"safety\": {\n        \"max_temperature\": 60,\n        \"max_discharge_current\": 15,\n        \"emergency_shutdown_enabled\": true,\n        \"auto_recovery_enabled\": true,\n        \"fuse_rating\": 20\n    },\n    \"monitoring\": {\n        \"log_interval_seconds\": 60,\n        \"data_retention_days\": 30,\n        \"enable_remote_monitoring\": true,\n        \"enable_data_logging\": true\n    },\n    \"interface\": {\n        \"mobile_app_enabled\": true,\n        \"remote_control_enabled\": true,\n        \"web_interface_enabled\": false,\n        \"api_enabled\": false\n    },\n    \"performance_targets\": {\n        \"backup_time_hours\": 4.5,\n        \"charging_time_hours\": 6,\n        \"system_efficiency\": 0.70,\n        \"battery_cycles\": 500\n    }\n}