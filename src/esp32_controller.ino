/*\n  Portable Solar Power Generator - ESP32 Controller Code\n  MS Engineering College Final Year Project\n  \n  Team:\n  - Ritik Pandey (Team Leader & Best Friend)\n  - Rohit Ranjan (Main Developer)\n  - Nikki Kumari Yadav (Documentation)\n  - Om Singh (Research)\n*/\n\n#include <WiFi.h>\n#include <WebServer.h>\n#include <ArduinoJson.h>\n#include <EEPROM.h>\n\n// Pin Definitions\n#define SOLAR_VOLTAGE_PIN A0\n#define BATTERY_VOLTAGE_PIN A3\n#define CURRENT_SENSOR_PIN A6\n\n// Relay Control Pins\n#define LIGHT_RELAY_PIN 2\n#define FAN_RELAY_PIN 4\n#define CHARGER_RELAY_PIN 5\n#define SYSTEM_RELAY_PIN 18\n\n// Status LED Pins\n#define POWER_LED_PIN 19\n#define CHARGING_LED_PIN 21\n#define LOW_BATTERY_LED_PIN 22\n\n// System Variables\nfloat batteryVoltage = 0.0;\nfloat solarVoltage = 0.0;\nfloat chargingCurrent = 0.0;\nfloat batteryPercentage = 0.0;\nbool isCharging = false;\nbool systemOn = true;\n\n// Device States\nbool lightState = false;\nbool fanState = false;\nbool chargerState = false;\n\n// WiFi Configuration\nconst char* ssid = \"Solar_Generator_AP\";\nconst char* password = \"solar123\";\n\n// Web Server\nWebServer server(80);\n\n// Timing Variables\nunsigned long lastSensorRead = 0;\nunsigned long lastStatusUpdate = 0;\nconst unsigned long SENSOR_INTERVAL = 1000;  // 1 second\nconst unsigned long STATUS_INTERVAL = 5000;  // 5 seconds\n\nvoid setup() {\n  Serial.begin(115200);\n  Serial.println(\"Solar Power Generator ESP32 Starting...\");\n  \n  // Initialize pins\n  initializePins();\n  \n  // Initialize EEPROM\n  EEPROM.begin(512);\n  \n  // Load saved states\n  loadDeviceStates();\n  \n  // Setup WiFi Access Point\n  setupWiFiAP();\n  \n  // Setup Web Server\n  setupWebServer();\n  \n  // Initial sensor reading\n  readSensors();\n  \n  Serial.println(\"System initialized successfully!\");\n}\n\nvoid loop() {\n  // Handle web server requests\n  server.handleClient();\n  \n  // Read sensors periodically\n  if (millis() - lastSensorRead >= SENSOR_INTERVAL) {\n    readSensors();\n    updateSystemStatus();\n    lastSensorRead = millis();\n  }\n  \n  // Update status LEDs\n  if (millis() - lastStatusUpdate >= STATUS_INTERVAL) {\n    updateStatusLEDs();\n    checkSafetyConditions();\n    lastStatusUpdate = millis();\n  }\n  \n  delay(100);\n}\n\nvoid initializePins() {\n  // Relay pins as outputs\n  pinMode(LIGHT_RELAY_PIN, OUTPUT);\n  pinMode(FAN_RELAY_PIN, OUTPUT);\n  pinMode(CHARGER_RELAY_PIN, OUTPUT);\n  pinMode(SYSTEM_RELAY_PIN, OUTPUT);\n  \n  // LED pins as outputs\n  pinMode(POWER_LED_PIN, OUTPUT);\n  pinMode(CHARGING_LED_PIN, OUTPUT);\n  pinMode(LOW_BATTERY_LED_PIN, OUTPUT);\n  \n  // Analog pins for sensors\n  pinMode(SOLAR_VOLTAGE_PIN, INPUT);\n  pinMode(BATTERY_VOLTAGE_PIN, INPUT);\n  pinMode(CURRENT_SENSOR_PIN, INPUT);\n  \n  // Initialize all relays to OFF\n  digitalWrite(LIGHT_RELAY_PIN, LOW);\n  digitalWrite(FAN_RELAY_PIN, LOW);\n  digitalWrite(CHARGER_RELAY_PIN, LOW);\n  digitalWrite(SYSTEM_RELAY_PIN, HIGH); // System relay ON by default\n}\n\nvoid readSensors() {\n  // Read solar panel voltage (0-25V range with voltage divider)\n  int solarRaw = analogRead(SOLAR_VOLTAGE_PIN);\n  solarVoltage = (solarRaw * 3.3 / 4095.0) * 7.58; // Calibration factor\n  \n  // Read battery voltage (0-15V range)\n  int batteryRaw = analogRead(BATTERY_VOLTAGE_PIN);\n  batteryVoltage = (batteryRaw * 3.3 / 4095.0) * 4.55; // Calibration factor\n  \n  // Read charging current (ACS712 sensor)\n  int currentRaw = analogRead(CURRENT_SENSOR_PIN);\n  float currentVoltage = (currentRaw * 3.3 / 4095.0);\n  chargingCurrent = (currentVoltage - 1.65) / 0.1; // ACS712-20A sensitivity\n  \n  // Calculate battery percentage (10.5V = 0%, 12.6V = 100%)\n  batteryPercentage = ((batteryVoltage - 10.5) / (12.6 - 10.5)) * 100.0;\n  batteryPercentage = constrain(batteryPercentage, 0, 100);\n  \n  // Determine charging status\n  isCharging = (solarVoltage > 13.0 && chargingCurrent > 0.1);\n}\n\nvoid updateSystemStatus() {\n  // Print status to serial\n  Serial.println(\"=== System Status ===\");\n  Serial.println(\"Solar Voltage: \" + String(solarVoltage, 2) + \"V\");\n  Serial.println(\"Battery Voltage: \" + String(batteryVoltage, 2) + \"V\");\n  Serial.println(\"Battery Percentage: \" + String(batteryPercentage, 1) + \"%\");\n  Serial.println(\"Charging Current: \" + String(chargingCurrent, 2) + \"A\");\n  Serial.println(\"Charging: \" + String(isCharging ? \"Yes\" : \"No\"));\n  Serial.println(\"Light: \" + String(lightState ? \"ON\" : \"OFF\"));\n  Serial.println(\"Fan: \" + String(fanState ? \"ON\" : \"OFF\"));\n  Serial.println(\"Charger: \" + String(chargerState ? \"ON\" : \"OFF\"));\n  Serial.println();\n}\n\nvoid updateStatusLEDs() {\n  // Power LED - Always ON when system is running\n  digitalWrite(POWER_LED_PIN, systemOn ? HIGH : LOW);\n  \n  // Charging LED - ON when charging\n  digitalWrite(CHARGING_LED_PIN, isCharging ? HIGH : LOW);\n  \n  // Low Battery LED - ON when battery < 20%\n  digitalWrite(LOW_BATTERY_LED_PIN, (batteryPercentage < 20) ? HIGH : LOW);\n}\n\nvoid checkSafetyConditions() {\n  // Emergency shutdown if battery too low\n  if (batteryVoltage < 10.5) {\n    emergencyShutdown();\n  }\n  \n  // Auto-disconnect loads if battery < 15%\n  if (batteryPercentage < 15) {\n    if (lightState || fanState || chargerState) {\n      Serial.println(\"Low battery! Disconnecting loads...\");\n      controlDevice(\"light\", false);\n      controlDevice(\"fan\", false);\n      controlDevice(\"charger\", false);\n    }\n  }\n}\n\nvoid emergencyShutdown() {\n  Serial.println(\"EMERGENCY SHUTDOWN - Critical battery level!\");\n  \n  // Turn off all loads\n  digitalWrite(LIGHT_RELAY_PIN, LOW);\n  digitalWrite(FAN_RELAY_PIN, LOW);\n  digitalWrite(CHARGER_RELAY_PIN, LOW);\n  \n  // Update states\n  lightState = false;\n  fanState = false;\n  chargerState = false;\n  \n  // Flash low battery LED\n  for (int i = 0; i < 10; i++) {\n    digitalWrite(LOW_BATTERY_LED_PIN, HIGH);\n    delay(200);\n    digitalWrite(LOW_BATTERY_LED_PIN, LOW);\n    delay(200);\n  }\n}\n\nvoid controlDevice(String device, bool state) {\n  if (device == \"light\") {\n    digitalWrite(LIGHT_RELAY_PIN, state ? HIGH : LOW);\n    lightState = state;\n  } else if (device == \"fan\") {\n    digitalWrite(FAN_RELAY_PIN, state ? HIGH : LOW);\n    fanState = state;\n  } else if (device == \"charger\") {\n    digitalWrite(CHARGER_RELAY_PIN, state ? HIGH : LOW);\n    chargerState = state;\n  }\n  \n  // Save state to EEPROM\n  saveDeviceStates();\n  \n  Serial.println(device + \" turned \" + (state ? \"ON\" : \"OFF\"));\n}\n\nvoid setupWiFiAP() {\n  WiFi.softAP(ssid, password);\n  IPAddress IP = WiFi.softAPIP();\n  Serial.println(\"AP IP address: \" + IP.toString());\n  Serial.println(\"WiFi AP started: \" + String(ssid));\n}\n\nvoid setupWebServer() {\n  // Serve main page\n  server.on(\"/\", handleRoot);\n  \n  // API endpoints\n  server.on(\"/api/status\", handleStatus);\n  server.on(\"/api/control\", HTTP_POST, handleControl);\n  server.on(\"/api/emergency\", HTTP_POST, handleEmergency);\n  \n  // Enable CORS\n  server.enableCORS(true);\n  \n  server.begin();\n  Serial.println(\"Web server started on port 80\");\n}\n\nvoid handleRoot() {\n  String html = R\"(\n<!DOCTYPE html>\n<html>\n<head>\n    <title>Solar Power Generator</title>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <style>\n        body { font-family: Arial; margin: 20px; background: #f0f0f0; }\n        .container { max-width: 600px; margin: 0 auto; background: white; padding: 20px; border-radius: 10px; }\n        .status { background: #e8f5e8; padding: 15px; border-radius: 5px; margin: 10px 0; }\n        .controls { background: #f0f8ff; padding: 15px; border-radius: 5px; margin: 10px 0; }\n        button { padding: 10px 20px; margin: 5px; border: none; border-radius: 5px; cursor: pointer; }\n        .on { background: #4CAF50; color: white; }\n        .off { background: #f44336; color: white; }\n        .emergency { background: #ff9800; color: white; font-weight: bold; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>🌞 Solar Power Generator</h1>\n        <div class=\"status\">\n            <h3>System Status</h3>\n            <p>Battery: <span id=\"battery\">--</span>% (<span id=\"batteryV\">--</span>V)</p>\n            <p>Solar: <span id=\"solar\">--</span>V</p>\n            <p>Current: <span id=\"current\">--</span>A</p>\n            <p>Charging: <span id=\"charging\">--</span></p>\n        </div>\n        <div class=\"controls\">\n            <h3>Device Control</h3>\n            <button id=\"lightBtn\" onclick=\"toggleDevice('light')\">Light: OFF</button>\n            <button id=\"fanBtn\" onclick=\"toggleDevice('fan')\">Fan: OFF</button>\n            <button id=\"chargerBtn\" onclick=\"toggleDevice('charger')\">Charger: OFF</button>\n            <br><br>\n            <button class=\"emergency\" onclick=\"emergency()\">EMERGENCY SHUTDOWN</button>\n        </div>\n    </div>\n    <script>\n        function updateStatus() {\n            fetch('/api/status')\n            .then(response => response.json())\n            .then(data => {\n                document.getElementById('battery').textContent = data.batteryPercentage.toFixed(1);\n                document.getElementById('batteryV').textContent = data.batteryVoltage.toFixed(2);\n                document.getElementById('solar').textContent = data.solarVoltage.toFixed(2);\n                document.getElementById('current').textContent = data.chargingCurrent.toFixed(2);\n                document.getElementById('charging').textContent = data.isCharging ? 'Yes' : 'No';\n                \n                updateButton('lightBtn', 'Light', data.lightState);\n                updateButton('fanBtn', 'Fan', data.fanState);\n                updateButton('chargerBtn', 'Charger', data.chargerState);\n            });\n        }\n        \n        function updateButton(id, name, state) {\n            const btn = document.getElementById(id);\n            btn.textContent = name + ': ' + (state ? 'ON' : 'OFF');\n            btn.className = state ? 'on' : 'off';\n        }\n        \n        function toggleDevice(device) {\n            fetch('/api/control', {\n                method: 'POST',\n                headers: {'Content-Type': 'application/json'},\n                body: JSON.stringify({device: device, action: 'toggle'})\n            }).then(() => updateStatus());\n        }\n        \n        function emergency() {\n            if (confirm('Emergency shutdown will turn off all devices. Continue?')) {\n                fetch('/api/emergency', {method: 'POST'})\n                .then(() => updateStatus());\n            }\n        }\n        \n        setInterval(updateStatus, 2000);\n        updateStatus();\n    </script>\n</body>\n</html>\n)\";\n  \n  server.send(200, \"text/html\", html);\n}\n\nvoid handleStatus() {\n  DynamicJsonDocument doc(1024);\n  \n  doc[\"batteryVoltage\"] = batteryVoltage;\n  doc[\"solarVoltage\"] = solarVoltage;\n  doc[\"chargingCurrent\"] = chargingCurrent;\n  doc[\"batteryPercentage\"] = batteryPercentage;\n  doc[\"isCharging\"] = isCharging;\n  doc[\"lightState\"] = lightState;\n  doc[\"fanState\"] = fanState;\n  doc[\"chargerState\"] = chargerState;\n  doc[\"systemOn\"] = systemOn;\n  \n  String response;\n  serializeJson(doc, response);\n  \n  server.send(200, \"application/json\", response);\n}\n\nvoid handleControl() {\n  if (server.hasArg(\"plain\")) {\n    DynamicJsonDocument doc(1024);\n    deserializeJson(doc, server.arg(\"plain\"));\n    \n    String device = doc[\"device\"];\n    String action = doc[\"action\"];\n    \n    if (action == \"toggle\") {\n      if (device == \"light\") {\n        controlDevice(\"light\", !lightState);\n      } else if (device == \"fan\") {\n        controlDevice(\"fan\", !fanState);\n      } else if (device == \"charger\") {\n        controlDevice(\"charger\", !chargerState);\n      }\n    }\n    \n    server.send(200, \"application/json\", \"{\\\"status\\\":\\\"ok\\\"}\");\n  } else {\n    server.send(400, \"application/json\", \"{\\\"error\\\":\\\"invalid request\\\"}\");\n  }\n}\n\nvoid handleEmergency() {\n  emergencyShutdown();\n  server.send(200, \"application/json\", \"{\\\"status\\\":\\\"emergency shutdown executed\\\"}\");\n}\n\nvoid saveDeviceStates() {\n  EEPROM.write(0, lightState ? 1 : 0);\n  EEPROM.write(1, fanState ? 1 : 0);\n  EEPROM.write(2, chargerState ? 1 : 0);\n  EEPROM.commit();\n}\n\nvoid loadDeviceStates() {\n  lightState = EEPROM.read(0) == 1;\n  fanState = EEPROM.read(1) == 1;\n  chargerState = EEPROM.read(2) == 1;\n  \n  // Apply loaded states to relays\n  digitalWrite(LIGHT_RELAY_PIN, lightState ? HIGH : LOW);\n  digitalWrite(FAN_RELAY_PIN, fanState ? HIGH : LOW);\n  digitalWrite(CHARGER_RELAY_PIN, chargerState ? HIGH : LOW);\n}